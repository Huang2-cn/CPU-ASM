    30                              <1> %macro draw_window 5 ;显示窗口框架 draw_window 起始X,起始Y,长,宽,标题指针
    31                              <1>     pushad
    32                              <1>         fill_rectangle 0e0h,%1 - 1,%2 - 1,%3 + 2,%4 + 2     ;主体框架
    33                              <1>         fill_rectangle 0ffh,%1,%2,%3,%4     ;主体框架 
    34                              <1>         push eax  
    35                              <1>         mov eax,%4         
    36                              <1>         mov [window_lenth],eax
    37                              <1>         sub eax,4
    38                              <1>         mov [line_lenth],eax
    39                              <1>         pop eax
    40                              <1>         fill_rectangle 010h,%1 + 4,%2 + 4,12,12     ;LOGO 
    41                              <1>         fill_rectangle 0F8h,%1 + 6,%2 + 6,8,8
    42                              <1>         fill_rectangle 010h,%1 + 8,%2 + 13,1,4
    43                              <1>         mov [print_X],dword %1 + 20
    44                              <1>         mov [print_Y],dword %2
    45                              <1>         mov [line_start],dword %1 + 2
    46                              <1>         printc 0FFh,%5
    47                              <1>         fill_rectangle 07h,%1,%2 + 18,1,%4
    48                              <1>         mov [print_X],dword %1 + 2
    49                              <1>         mov [print_Y],dword %2 + 20
    50                              <1>     popad
    51                              <1> %endmacro
