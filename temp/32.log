    62                              <1> %macro cmpstr 3      ;格式:cmpstr 字符串1,字符串2,相等跳转的标号
    63                              <1>     pushad
    64                              <1>     mov esi,%1
    65                              <1>     mov edi,%2
    66                              <1>     %%compare:
    67                              <1>         mov ah,[esi]
    68                              <1>         mov al,[edi]
    69                              <1>         inc esi
    70                              <1>         inc edi
    71                              <1>         cmp ah,al
    72                              <1>         jne %%not_equal
    73                              <1>         cmp ah,0    ;判断字符串是否结束
    74                              <1>         jne %%compare
    75                              <1>                     ;已结束
    76                              <1>             popad
    77                              <1>             jmp %3  ;执行调用定义的命令    
    78                              <1>     %%not_equal:
    79                              <1>     popad
    80                              <1> %endmacro
