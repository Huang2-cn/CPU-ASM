   112                              <1> %macro cmpstr 3      ;格式:cmpstr 字符串1,字符串2,相等跳转的标号
   113                              <1>     pushad
   114                              <1>     mov esi,%1
   115                              <1>     mov edi,%2
   116                              <1>     %%compare:
   117                              <1>         mov ah,[esi]
   118                              <1>         mov al,[edi]
   119                              <1>         inc esi
   120                              <1>         inc edi
   121                              <1>         cmp ah,al
   122                              <1>         jne %%not_equal
   123                              <1>         cmp ah,0    ;判断字符串是否结束
   124                              <1>         jne %%compare
   125                              <1>                     ;已结束
   126                              <1>             popad
   127                              <1>             jmp %3  ;执行调用定义的命令    
   128                              <1>     %%not_equal:
   129                              <1>     popad
   130                              <1> %endmacro
