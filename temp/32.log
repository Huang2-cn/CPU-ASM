    85                              <1>     mov esi,%2
    86                              <1>     .copy:
    87                              <1>         mov al,[esi]
    88                              <1>         stosb
    89                              <1>         inc esi
    90                              <1>         cmp al,0
    91                              <1>     jne .copy
    92                              <1>     popad
    93                              <1> %endmacro
