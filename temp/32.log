    39                              <1> %macro draw_window 5 ;显示窗口框架 draw_window 起始X,起始Y,长,宽,标题指针
    40                              <1>     pushad
    41                              <1>         fill_rectangle 0e0h,%1 - 1,%2 - 1,%3 + 2,%4 + 2     ;主体框架
    42                              <1>         fill_rectangle 0ffh,%1,%2,%3,%4     ;主体框架 
    43                              <1>         push eax  
    44                              <1>         mov eax,%4         
    45                              <1>         mov [window_lenth],eax
    46                              <1>         sub eax,4
    47                              <1>         mov [line_lenth],eax
    48                              <1>         pop eax
    49                              <1>         fill_rectangle 010h,%1 + 4,%2 + 4,12,12     ;LOGO 
    50                              <1>         fill_rectangle 0F8h,%1 + 6,%2 + 6,8,8
    51                              <1>         fill_rectangle 010h,%1 + 8,%2 + 13,1,4
    52                              <1>         mov [print_X],dword %1 + 20
    53                              <1>         mov [print_Y],dword %2
    54                              <1>         mov [line_start],dword %1 + 2
    55                              <1>         printc 0FFh,%5
    56                              <1>         fill_rectangle 07h,%1,%2 + 18,1,%4
    57                              <1>         mov [print_X],dword %1 + 2
    58                              <1>         mov [print_Y],dword %2 + 20
    59                              <1>     popad
    60                              <1> %endmacro
