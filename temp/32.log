    75                              <1>     mov edi,%1
    76                              <1>     mov esi,%2
    77                              <1>     .copy:
    78                              <1>         mov al,[esi]
    79                              <1>         stosb
    80                              <1>         inc esi
    81                              <1>         cmp al,0
    82                              <1>     jne .copy
    83                              <1>     popad
    84                              <1> %endmacro
