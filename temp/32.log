   114                              <1> %macro cmpstr 3      ;格式:cmpstr 字符串1,字符串2,相等跳转的标号
   115                              <1>     pushad
   116                              <1>     mov esi,%1
   117                              <1>     mov edi,%2
   118                              <1>     %%compare:
   119                              <1>         mov ah,[esi]
   120                              <1>         mov al,[edi]
   121                              <1>         inc esi
   122                              <1>         inc edi
   123                              <1>         cmp ah,al
   124                              <1>         jne %%not_equal
   125                              <1>         cmp ah,0    ;判断字符串是否结束
   126                              <1>         jne %%compare
   127                              <1>                     ;已结束
   128                              <1>             popad
   129                              <1>             jmp %3  ;执行调用定义的命令    
   130                              <1>     %%not_equal:
   131                              <1>     popad
   132                              <1> %endmacro
