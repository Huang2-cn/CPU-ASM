    53                              <1> %macro cmpstr 3      ;格式:cmpstr 字符串1,字符串2,相等跳转的标号
    54                              <1>     pushad
    55                              <1>     mov esi,%1
    56                              <1>     mov edi,%2
    57                              <1>     %%compare:
    58                              <1>         mov ah,[esi]
    59                              <1>         mov al,[edi]
    60                              <1>         inc esi
    61                              <1>         inc edi
    62                              <1>         cmp ah,al
    63                              <1>         jne %%not_equal
    64                              <1>         cmp ah,0    ;判断字符串是否结束
    65                              <1>         jne %%compare
    66                              <1>                     ;已结束
    67                              <1>             popad
    68                              <1>             jmp %3  ;执行调用定义的命令    
    69                              <1>     %%not_equal:
    70                              <1>     popad
    71                              <1> %endmacro
