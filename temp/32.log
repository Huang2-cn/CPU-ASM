   108                              <1> %macro cmpstr 3      ;格式:cmpstr 字符串1,字符串2,相等跳转的标号
   109                              <1>     pushad
   110                              <1>     mov esi,%1
   111                              <1>     mov edi,%2
   112                              <1>     %%compare:
   113                              <1>         mov ah,[esi]
   114                              <1>         mov al,[edi]
   115                              <1>         inc esi
   116                              <1>         inc edi
   117                              <1>         cmp ah,al
   118                              <1>         jne %%not_equal
   119                              <1>         cmp ah,0    ;判断字符串是否结束
   120                              <1>         jne %%compare
   121                              <1>                     ;已结束
   122                              <1>             popad
   123                              <1>             jmp %3  ;执行调用定义的命令    
   124                              <1>     %%not_equal:
   125                              <1>     popad
   126                              <1> %endmacro
